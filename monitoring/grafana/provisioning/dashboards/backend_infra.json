{
  "title": "Backend Infrastructure & DB Pools [From: Prometheus]",
  "uid": "backend_infra",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Database Connections (Active vs Idle)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "Active DB Conns" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "Idle DB Conns" }
      ]
    },
    {
      "id": 2,
      "title": "JVM Heap Memory Allocation",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "Used Heap" },
        { "expr": "jvm_memory_committed_bytes{area=\"heap\"}", "legendFormat": "Committed Heap" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}