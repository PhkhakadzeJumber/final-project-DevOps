{
  "title": "Memory Management & Heap Analysis",
  "uid": "memory_management",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "GOGC Target Config",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "go_gc_gogc_percent", "legendFormat": "% growth limit" }]
    },
    {
      "id": 2,
      "title": "Configured Memory Limit",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "go_gc_gomemlimit_bytes", "legendFormat": "Max Bytes" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "title": "Heap Live Volume vs Next GC Target",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "go_gc_heap_live_bytes", "legendFormat": "Live Heap" },
        { "expr": "go_gc_heap_goal_bytes", "legendFormat": "Target Goal" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "title": "Allocation and Free Operations (Rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(go_gc_heap_allocs_bytes_total[1m])", "legendFormat": "Allocated/sec" },
        { "expr": "rate(go_gc_heap_frees_bytes_total[1m])", "legendFormat": "Freed/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ]
}