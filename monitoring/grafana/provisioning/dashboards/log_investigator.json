{
  "title": "Application Log Investigator [From: Loki]",
  "uid": "log_investigator",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Log Generation Frequency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "count_over_time({job=\"docker\"}[1m])", "legendFormat": "Lines/Min" }]
    },
    {
      "id": 2,
      "title": "Live App Streams",
      "type": "logs",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{job=\"docker\"}", "legendFormat": "" }],
      "options": { "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ]
}